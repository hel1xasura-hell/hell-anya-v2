# ──────────────────────────────────────────────────────────────
# ᴀɴʏᴀ — Environment Configuration
# Copy this file to `.env` and fill in real values.
# NEVER commit your actual `.env` file.
# ──────────────────────────────────────────────────────────────

# --- Telegram Bot API credentials (https://my.telegram.org + @BotFather) ---
BOT_TOKEN=123456789:AAExampleTokenFromBotFather
API_ID=12345678
API_HASH=your_api_hash_here

# --- Assistant user session (required for joining voice chats) ---
# Generate with a Pyrogram session-string exporter using the same API_ID/API_HASH.
# The assistant account MUST already be a member of ALLOWED_GROUP_ID.
SESSION_STRING=

# --- Access control ---
OWNER_ID=111111111
ALLOWED_GROUP_ID=-1001234567890

# --- Optional logging channel (numeric chat id, bot must be a member/admin) ---
LOG_CHANNEL=

# --- Optional: Spotify Web API (client-credentials flow) ---
# https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# --- Optional: Genius API token, improves /lyrics hit-rate ---
# https://genius.com/api-clients
GENIUS_API_TOKEN=

# --- Optional: YouTube cookies, base64-encoded cookies.txt content ---
# Fixes "Sign in to confirm you're not a bot" errors on cloud IPs (e.g. Railway).
# See README "YouTube Cookies" section for exact export/encode steps.
# Use a secondary/throwaway Google account — not your main one.
YOUTUBE_COOKIES_B64=

# --- Behavioural tuning (all optional, sane defaults applied) ---
INACTIVITY_TIMEOUT_SECONDS=300
DEFAULT_VOLUME=100
MAX_QUEUE_SIZE=50

